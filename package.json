{
  "name": "random-ip-gen",
  "version": "1.1.1",
  "description": "Generate unique random IPv4 and IPv6 addresses with validation support",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ip",
    "ipv4",
    "ipv6",
    "random",
    "generator",
    "validation",
    "network",
    "address",
    "unique",
    "object-oriented"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "author": {
    "name": "Navnath Kadam",
    "email": "navnathkadam284@gmail.com",
    "url": "https://github.com/ndk123-web"
  },
  "homepage": "https://github.com/ndk123-web/random-ip-generator",
  "repository": {
    "url": "https://github.com/ndk123-web/random-ip-generator",
    "type": "git"
  },
  "dependencies": {}
}
